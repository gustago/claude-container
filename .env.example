# Chave da API da Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Chave da API do Google AI Studio (para Antigravity CLI / agy)
GEMINI_API_KEY=

# Caminho dos projetos na VPS (host)
PROJECTS_PATH_HOST=/home/projects

# Caminho equivalente dentro do container (usado no volume, Dockerfile e claude-enter)
PROJECTS_PATH_CONTAINER=/home/projects
